// Runs once at power-on
void setup(){
  Serial.begin(115200); delay(500);
  Serial.println(F("BUILD: v20-dsp"));

  pinMode(RESET_BTN,INPUT_PULLUP);
  pinMode(MODE_BTN, INPUT_PULLUP);
  pinMode(19,INPUT_PULLUP); // MISO pullup — prevents TFT GRAM noise
  pinMode(TFT_LED_PIN,OUTPUT); digitalWrite(TFT_LED_PIN,HIGH);

  // Restart the display chip so it starts fresh
  pinMode(5,OUTPUT); pinMode(22,OUTPUT); pinMode(4,OUTPUT);
  digitalWrite(22,HIGH); digitalWrite(5,HIGH); delay(10);
  digitalWrite(5,LOW);   delay(20);
  digitalWrite(5,HIGH);  delay(150);

  tft.init();
  tft.setRotation(3);
  tft.fillScreen(TFT_BLACK);
  tft.fillScreen(TFT_BLACK);

  tft.setTextColor(C_CYAN,C_BG); tft.setTextSize(2);
  tft.setCursor(50,100); tft.print("Sound Dosimeter");
  tft.setTextColor(C_DIM,C_BG); tft.setTextSize(1);
  tft.setCursor(90,124); tft.print("v20-dsp  booting...");

  prefs.begin("dosimeter",false);
  sessionCount=prefs.getUChar("scount",0);
  if(sessionCount>0) prefs.getBytes("sessions",sessions,sizeof(sessions));

  // Start the microphone task running on the second processor core
  samples_queue = xQueueCreate(8, sizeof(SumBlock));
  xTaskCreatePinnedToCore(i2s_reader_task,"I2S",8192,NULL,4,NULL,0);

  WiFi.softAP(WIFI_SSID,WIFI_PASS);
  IPAddress ip=WiFi.softAPIP();
  Serial.print(F("IP: ")); Serial.println(ip);

  webServer=new WebServer(80);
  webServer->on("/",        handleRoot);
  webServer->on("/data",    handleData);
  webServer->on("/sessions",handleSessions);
  webServer->on("/reset",   handleReset);
  webServer->begin();

  // Show WiFi connection info while system finishes starting up
  tft.fillScreen(C_BG);
  tft.setTextColor(C_CYAN,C_BG); tft.setTextSize(2);
  tft.setCursor(30,80); tft.print("Sound Dosimeter");
  tft.setTextColor(C_DIM,C_BG); tft.setTextSize(1);
  tft.setCursor(30,110); tft.print("WiFi : SoundDosimeter");
  tft.setCursor(30,124); tft.print("Pass : 12345678");
  tft.setCursor(30,138); tft.print("URL  : http://"); tft.print(ip);
  tft.setCursor(30,160); tft.print("Initialising...");
  delay(2000);
  tft.fillScreen(C_BG);
  delay(100);

  lastSecMs=millis();
  needFullRedraw=true;
}

// Runs over and over — checks for new measurements, button presses, and updates the screen
void loop(){
  SumBlock q;

  // Grab any fresh audio measurements from the mic task
  while(xQueueReceive(samples_queue, &q, 0)==pdTRUE){
    double spl_dB      = to_dB(q.sum_sqr_spl, SAMPLES_SHORT);
    double weighted_dB = to_dB(q.sum_sqr_weighted, SAMPLES_SHORT);

    bool overloaded = (spl_dB > MIC_OVERLOAD_DB);
    bool too_quiet  = (weighted_dB < MIC_NOISE_DB || isnan(weighted_dB));
    micConnected    = (!isnan(spl_dB) && spl_dB > MIC_NOISE_DB);

    if(!overloaded && !too_quiet){
      currentDB = (float)weighted_dB;
      if(currentDB > peakDB) peakDB = currentDB;

      // Running average sound level (energy-averaged, not simple average)
      leq_sum_sqr    += q.sum_sqr_weighted;
      leq_total_samp += SAMPLES_SHORT;
      if(leq_total_samp>0)
        leqDB=(float)to_dB(leq_sum_sqr, leq_total_samp);

      // Work out what fraction of the safe daily noise dose has been used up
      float T=DOSE_HOURS/powf(2.0f,(currentDB-DOSE_CRITERION)/EXCHANGE_RATE);
      if(T>0){
        float dt=(float)SAMPLES_SHORT/(float)SAMPLE_RATE/3600.0f;
        dosePercent+=(dt/T)*100.0f;
      }
      if(dosePercent>=0.01f){
        twaDB=90.0f+EXCHANGE_RATE*log2f(dosePercent/100.0f);
        if(twaDB<0) twaDB=0;
      }

      // Store the sound level for each frequency band
      for(int b=0;b<NUM_BANDS;b++){
        float sp=(float)to_dB(q.sum_sqr_band[b], SAMPLES_SHORT);
        sp=constrain(sp,0.0f,140.0f);
        bandSPL[b]=sp; if(sp>bandPeak[b]) bandPeak[b]=sp;
      }

      // Save this reading to the scrolling history for the chart on the web app
      splHistory[histIdx]=currentDB;
      histIdx=(histIdx+1)%HISTORY_LEN;
      if(histCount<HISTORY_LEN) histCount++;

      buzzerActive=(currentDB>=ALERT_SPL||dosePercent>=ALERT_DOSE);
    }

    // Print readings to the computer every second so we can check via USB
    static uint32_t lastSer=0;
    if(millis()-lastSer>1000){lastSer=millis();
      Serial.printf("screen=%d SPL:%.1f Leq:%.1f Dose:%.2f%% TWA:%.1f\n",
        screen,currentDB,leqDB,dosePercent,twaDB);
    }
  }

  // Check if someone pressed the reset button — save and clear the session
  bool rn=digitalRead(RESET_BTN);
  if(lastReset==HIGH && rn==LOW){delay(50);if(digitalRead(RESET_BTN)==LOW)resetMeasurement();}
  lastReset=rn;

  // Check if someone pressed the mode button — switch to the next screen
  static bool lastMode=HIGH;
  bool mn=digitalRead(MODE_BTN);
  if(lastMode==HIGH && mn==LOW){
    delay(50);
    if(digitalRead(MODE_BTN)==LOW){screen=(screen+1)%NUM_SCREENS;needFullRedraw=true;}
  }
  lastMode=mn;

  // Count up the session timer every second
  if(millis()-lastSecMs>=1000){lastSecMs=millis();sessionSec++;}

  // Refresh the screen — full redraw on screen change, partial update every 200ms
  if(needFullRedraw){
    drawScreen();
  } else if(millis()-lastPartialMs>=200){
    lastPartialMs=millis();
    partialUpdate();
  }

  // Handle any web dashboard requests from connected devices
  webServer->handleClient();
}
