void drawScreen(){
  switch(screen){
    case 0: drawSPLDose_full(); drawSPLDose_update(); break;
    case 1: drawSpectrum_full();                      break;
    case 2: drawSessions_full();                      break;
  }
  needFullRedraw=false;
}

void partialUpdate(){
  switch(screen){
    case 0: drawSPLDose_update();   break;
    case 1: drawSpectrum_partial(); break;
    case 2:                         break;
  }
}

// WiFi web dashboard — serves the live data to any phone or laptop connected
void setHeaders(){
  webServer->sendHeader("Connection","close");
  webServer->sendHeader("Access-Control-Allow-Origin","*");
  webServer->sendHeader("Cache-Control","no-cache, no-store, must-revalidate");
  webServer->sendHeader("Pragma","no-cache"); webServer->sendHeader("Expires","0");
}

void handleData(){
  setHeaders();
  char ts[12]; formatTime(sessionSec,ts);
  String hist="["; uint8_t cnt=min((int)histCount,(int)HISTORY_LEN);
  for(int i=0;i<cnt;i++){uint8_t idx=(histIdx-cnt+i+HISTORY_LEN)%HISTORY_LEN;if(i>0)hist+=",";hist+=String(splHistory[idx],1);}
  hist+="]";
  String bands="["; for(int b=0;b<NUM_BANDS;b++){if(b>0)bands+=",";bands+=String(bandSPL[b],1);} bands+="]";
  String peaks="["; for(int b=0;b<NUM_BANDS;b++){if(b>0)peaks+=",";peaks+=String(bandPeak[b],1);} peaks+="]";
  String twaStr=(dosePercent>=0.01f)?String(twaDB,1):"null";
  String json="{\"spl\":"+String(currentDB,1)+",\"leq\":"+String(leqDB,1)+
    ",\"peak\":"+String(peakDB,1)+",\"dose\":"+String(dosePercent,2)+
    ",\"twa\":"+twaStr+",\"time\":\""+String(ts)+"\""+
    ",\"history\":"+hist+",\"bands\":"+bands+",\"peaks\":"+peaks+"}";
  webServer->send(200,"application/json",json);
}

void handleSessions(){
  setHeaders(); String json="[";
  for(int i=0;i<sessionCount;i++){
    if(i>0)json+=","; char ts[12]; formatTime(sessions[i].duration,ts);
    String tw=(sessions[i].twa>0)?String(sessions[i].twa,1):"null";
    json+="{\"n\":"+String(i+1)+",\"dur\":\""+String(ts)+"\",\"leq\":"+String(sessions[i].leq,1)+
      ",\"peak\":"+String(sessions[i].peakSPL,1)+",\"dose\":"+String(sessions[i].dose,2)+",\"twa\":"+tw+"}";
  }
  json+="]"; webServer->send(200,"application/json",json);
}

void handleReset(){
  setHeaders(); resetMeasurement();
  webServer->send(200,"application/json","{\"ok\":true}");
}

