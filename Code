// Screen 2: Spectrum — shows the 9 frequency bands as a bar chart
void drawSpectrum_full(){
  tft.fillScreen(C_BG);
  drawHeader("Octave bands");
  const int barW=28,gap=5,startX=10,baseY=218,maxH=176;
  for(int b=0;b<NUM_BANDS;b++){
    int x=startX+b*(barW+gap);
    tft.fillRect(x,baseY-maxH,barW,maxH,C_PANEL);
    tft.setTextSize(1); tft.setTextColor(C_DIM,C_BG);
    tft.setCursor(x+(barW-(int)strlen(bandLabel[b])*6)/2,baseY+3);
    tft.print(bandLabel[b]);
  }
  memset(specPrevH,-1,sizeof(specPrevH));
  memset(specPrevPkH,-1,sizeof(specPrevPkH));
}

void drawSpectrum_partial(){
  const int barW=28,gap=5,startX=10,baseY=218,maxH=176;
  for(int b=0;b<NUM_BANDS;b++){
    int x=startX+b*(barW+gap);
    int barH=constrain((int)(bandSPL[b]/140.0f*(float)maxH),0,maxH);
    int pkH =constrain((int)(bandPeak[b]/140.0f*(float)maxH),0,maxH);
    if(barH==specPrevH[b] && pkH==specPrevPkH[b]) continue;
    tft.fillRect(x,baseY-maxH,barW,maxH,C_PANEL);
    if(barH>0) tft.fillRect(x,baseY-barH,barW,barH,splColour(bandSPL[b]));
    if(pkH>0)  tft.drawFastHLine(x,baseY-pkH,barW,C_AMBER);
    tft.fillRect(x,baseY-maxH,barW,12,C_BG);
    if(bandSPL[b]>15){
      char tb[5]; sprintf(tb,"%.0f",bandSPL[b]);
      tft.setTextSize(1); tft.setTextColor(C_WHITE,C_BG);
      tft.setCursor(x+(barW-(int)strlen(tb)*6)/2,baseY-maxH);
      tft.print(tb);
    }
    specPrevH[b]=barH; specPrevPkH[b]=pkH;
  }
}

