  if(!micConnected){
    tft.setTextSize(1); tft.setTextColor(C_AMBER,C_PANEL);
    tft.setCursor(196,8); tft.print("NO MIC");
  }
  tft.drawFastHLine(0,24,320,C_BORDER);
}

void drawGradBar(int x,int y,int w,int h,float pct){
  tft.fillRect(x,y,w,h,C_PANEL);
  int filled=constrain((int)(pct*(float)w),0,w);
  for(int i=0;i<filled;i++){
    float p=(float)i/(float)w;
    uint16_t c=(p<0.54f)?C_GREEN:(p<0.75f)?C_AMBER:C_RED;
    tft.drawFastVLine(x+i,y,h,c);
  }
}

