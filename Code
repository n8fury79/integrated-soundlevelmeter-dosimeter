// ─── Sessions ─────────────────────────────────────────────────
// How many past sessions we save in the device's memory
#define MAX_SESSIONS 5
struct Session { uint32_t duration; float leq,peakSPL,dose,twa; };
Session  sessions[MAX_SESSIONS];
uint8_t  sessionCount=0;
Preferences prefs;

void formatTime(uint32_t s, char* buf){
  sprintf(buf,"%02lu:%02lu:%02lu",s/3600,(s%3600)/60,s%60);
}

void saveSession(){
  if(sessionSec<5) return;
  for(int i=MAX_SESSIONS-1;i>0;i--) sessions[i]=sessions[i-1];
  sessions[0]={sessionSec,leqDB,peakDB,dosePercent,(dosePercent>=0.01f)?twaDB:0.0f};
  if(sessionCount<MAX_SESSIONS) sessionCount++;
  prefs.putBytes("sessions",sessions,sizeof(sessions));
  prefs.putUChar("scount",sessionCount);
}

bool needFullRedraw=true; // forward-declared for resetMeasurement
void resetMeasurement(){
  saveSession();
  leq_sum_sqr=0; leq_total_samp=0;
  leqDB=dosePercent=currentDB=peakDB=twaDB=0;
  sessionSec=0; lastSecMs=millis(); histIdx=histCount=0;
  for(int b=0;b<NUM_BANDS;b++){bandSPL[b]=0;bandPeak[b]=0;}
  MIC_EQ.reset(); A_WEIGHT.reset();
  for(int b=0;b<NUM_BANDS;b++) octave[b].reset();
  needFullRedraw=true;
}

