// Sound processing block
#define SAMPLE_RATE      48000
#define SAMPLE_BITS      32
#define MIC_OFFSET_DB    3.0103
#define MIC_REF_DB       94.0
#define MIC_OVERLOAD_DB  120.0
#define MIC_NOISE_DB     33.0
const double MIC_REF_AMPL = 420426.9;

#define SAMPLES_SHORT  (SAMPLE_RATE / 8)   // 125ms = 6000 samples

static float samples[SAMPLES_SHORT] __attribute__((aligned(4)));
static float eq_samples[SAMPLES_SHORT] __attribute__((aligned(4))); // EQ-corrected copy for band filters

struct SOS_Coeff { float b1, b2, a1, a2; };

struct SOS_IIR_Filter {
  float            gain;
  const SOS_Coeff* sos;
  int              stages;
  float            w[4][2];

  void reset() { memset(w, 0, sizeof(w)); }

  float filter(float* src, float* dst, int n) {
    float sum_sqr = 0.0f;
    for (int i = 0; i < n; i++) {
      float x = src[i] * gain;
      for (int s = 0; s < stages; s++) {
        float in  = x + sos[s].a1 * w[s][0] + sos[s].a2 * w[s][1];
        float out = in + sos[s].b1 * w[s][0] + sos[s].b2 * w[s][1];
        w[s][1] = w[s][0]; w[s][0] = in; x = out;
      }
      dst[i] = x; sum_sqr += x * x;
    }
    return sum_sqr;
  }
};

// INMP441 EQ correction
static const SOS_Coeff sos_inmp441[] = {
  {-1.986920458344451f, +0.986963226946616f, +1.995178510504166f, -0.995184322194091f}
};
SOS_IIR_Filter MIC_EQ = { 1.00197834654696f, sos_inmp441, 1, {} };

// A-weighting fs=48000
static const SOS_Coeff sos_a_weight[] = {
  {-2.00026996133106f, +1.00027056142719f, -1.060868438509278f, -0.163987445885926f},
  {+4.35912384203144f, +3.09120265783884f, +1.208419926363593f, -0.273166998428332f},
  {-0.70930303489759f, -0.29071868393580f, +1.982242159753048f, -0.982298594928989f}
};
SOS_IIR_Filter A_WEIGHT = { 0.169994948147430f, sos_a_weight, 3, {} };

// Octave band filters fs=48000 (9 bands: 31.5Hz–8kHz)
#define NUM_BANDS 9
const char* bandLabel[NUM_BANDS] = {"31","63","125","250","500","1k","2k","4k","8k"};

// Splits the sound into 9 frequency bands (like a graphic equaliser)
// Each band covers one octave, from 31Hz bass up to 8kHz treble
struct BandFilter {
  float b0, a1, a2;  // b1=0, b2=-b0
  float x1,x2,y1,y2;
  void reset(){ x1=x2=y1=y2=0; }
  float filter(float* src, int n){
    float ss=0;
    for(int i=0;i<n;i++){
      float y = b0*src[i] - b0*x2 - a1*y1 - a2*y2;
      x2=x1; x1=src[i]; y2=y1; y1=y;
      ss+=y*y;
    }
    return ss;
  }
};

// Band filter settings — one row per band, from lowest to highest frequency
BandFilter octave[NUM_BANDS] = {
  {0.00145569f, -1.99707163f, 0.99708861f, 0,0,0,0}, // 31.5Hz
  {0.00290713f, -1.99411792f, 0.99418573f, 0,0,0,0}, // 63Hz
  {0.00575147f, -1.98823087f, 0.98849705f, 0,0,0,0}, // 125Hz
  {0.01143566f, -1.97607011f, 0.97712869f, 0,0,0,0}, // 250Hz
  {0.02260089f, -1.95061285f, 0.95479823f, 0,0,0,0}, // 500Hz
  {0.04411229f, -1.89541993f, 0.91177543f, 0,0,0,0}, // 1kHz
  {0.08383492f, -1.76989502f, 0.83233015f, 0,0,0,0}, // 2kHz
  {0.15022110f, -1.47186022f, 0.69955779f, 0,0,0,0}, // 4kHz
  {0.23441238f, -0.76558762f, 0.53117524f, 0,0,0,0}, // 8kHz
};

// SumBlock carries A-weighted + 9 band energy sums
struct SumBlock {
  float sum_sqr_spl;
  float sum_sqr_weighted;
  float sum_sqr_band[NUM_BANDS];
};
QueueHandle_t samples_queue;

double to_dB(double sum_sqr, uint32_t n) {
  if (sum_sqr <= 0.0 || n == 0) return 0.0;
  double rms = sqrt(sum_sqr / (double)n);
  return MIC_OFFSET_DB + MIC_REF_DB + 20.0 * log10(rms / MIC_REF_AMPL);
}

// ─── I2S reader task — core 0 ─────────────────────────────────
void i2s_reader_task(void*) {
  const i2s_config_t cfg = {
    .mode                 = i2s_mode_t(I2S_MODE_MASTER | I2S_MODE_RX),
    .sample_rate          = SAMPLE_RATE,
    .bits_per_sample      = i2s_bits_per_sample_t(SAMPLE_BITS),
    .channel_format       = I2S_CHANNEL_FMT_ONLY_LEFT,
    .communication_format = i2s_comm_format_t(I2S_COMM_FORMAT_I2S | I2S_COMM_FORMAT_I2S_MSB),
    .intr_alloc_flags     = ESP_INTR_FLAG_LEVEL1,
    .dma_buf_count        = 8,
    .dma_buf_len          = SAMPLES_SHORT / 8,
    .use_apll             = true,
    .tx_desc_auto_clear   = false,
    .fixed_mclk           = 0
  };
  const i2s_pin_config_t pins = {
    .bck_io_num   = I2S_SCK,
    .ws_io_num    = I2S_WS,
    .data_out_num = I2S_PIN_NO_CHANGE,
    .data_in_num  = I2S_SD
  };
  i2s_driver_install(I2S_PORT, &cfg, 0, NULL);
  i2s_set_pin(I2S_PORT, &pins);

  MIC_EQ.reset(); A_WEIGHT.reset();
  for(int b=0;b<NUM_BANDS;b++) octave[b].reset();

  size_t bytes_read = 0;
  // Discard first block — INMP441 startup transient
  i2s_read(I2S_PORT, &samples, SAMPLES_SHORT * sizeof(int32_t), &bytes_read, portMAX_DELAY);

  while (true) {
    i2s_read(I2S_PORT, &samples, SAMPLES_SHORT * sizeof(int32_t), &bytes_read, portMAX_DELAY);

    // Convert 32-bit I2S word → 24-bit float (shift out padding)
    int32_t* raw = (int32_t*)samples;
    for (int i = 0; i < SAMPLES_SHORT; i++)
      samples[i] = (float)(raw[i] >> 8);

    SumBlock q;
    // Step 1: Fix the microphone's own frequency response
    q.sum_sqr_spl      = MIC_EQ.filter(samples, eq_samples, SAMPLES_SHORT);
    // Step 2: Split into 9 frequency bands
    for(int b=0;b<NUM_BANDS;b++)
      q.sum_sqr_band[b] = octave[b].filter(eq_samples, SAMPLES_SHORT);
    // Step 3: Apply A-weighting so readings match what ears hear
    q.sum_sqr_weighted = A_WEIGHT.filter(eq_samples, samples, SAMPLES_SHORT);

    xQueueSend(samples_queue, &q, portMAX_DELAY);
  }
}

